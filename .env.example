# Clerk (https://dashboard.clerk.com → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_GET_FROM_CLERK_DASHBOARD
CLERK_SECRET_KEY=sk_test_GET_FROM_CLERK_DASHBOARD

# Clerk JWT issuer (Dashboard → API Keys → Advanced → JWT issuer)
# Format: https://<your-instance>.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=https://GET_FROM_CLERK_DASHBOARD.clerk.accounts.dev

# Clerk webhook secret (Dashboard → Webhooks → signing secret)
CLERK_WEBHOOK_SECRET=whsec_GET_FROM_CLERK_DASHBOARD

# Clerk route configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Convex (https://dashboard.convex.dev → your project → Settings)
NEXT_PUBLIC_CONVEX_URL=https://GET_FROM_CONVEX_DASHBOARD.convex.cloud

# Canvas integration
# No environment variables needed — users provide their own Canvas URL and
# personal access token through the dashboard UI. Tokens are stored server-side
# in Convex (canvasCredentials table) and never sent to the browser.
