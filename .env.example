# Clerk (https://dashboard.clerk.com → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_GET_FROM_CLERK_DASHBOARD
CLERK_SECRET_KEY=sk_test_GET_FROM_CLERK_DASHBOARD

# Clerk JWT issuer (Dashboard → API Keys → Advanced → JWT issuer)
# Format: https://<your-instance>.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=https://GET_FROM_CLERK_DASHBOARD.clerk.accounts.dev

# Clerk webhook secret (Dashboard → Webhooks → signing secret)
CLERK_WEBHOOK_SECRET=whsec_GET_FROM_CLERK_DASHBOARD

# Clerk route configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Convex (https://dashboard.convex.dev → your project → Settings)
NEXT_PUBLIC_CONVEX_URL=https://GET_FROM_CONVEX_DASHBOARD.convex.cloud

# Canvas SSO integration
# Cookie encryption is not currently enabled. Session cookies are stored as plain JSON
# in Convex. When encryption is re-enabled, set a 32-byte hex key here and in the
# Convex dashboard (Settings → Environment Variables).
#
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CANVAS_COOKIE_ENCRYPTION_KEY=SET_IN_CONVEX_DASHBOARD_AND_HERE

# Optional Playwright tuning (Next.js / local dev only)
# HEADLESS=false           # Show a real browser window (debugging)
# SESSION_CHECK_MS=2000    # How long to wait for a saved session to be detected
# SCREENSHOT_INTERVAL_MS=2500
# SCREENSHOT_QUALITY=35    # JPEG quality 0-100
