# Clerk (https://dashboard.clerk.com → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_GET_FROM_CLERK_DASHBOARD
CLERK_SECRET_KEY=sk_test_GET_FROM_CLERK_DASHBOARD

# Clerk JWT issuer (Dashboard → API Keys → Advanced → JWT issuer)
# Format: https://<your-instance>.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=https://GET_FROM_CLERK_DASHBOARD.clerk.accounts.dev

# Clerk webhook secret (Dashboard → Webhooks → signing secret)
CLERK_WEBHOOK_SECRET=whsec_GET_FROM_CLERK_DASHBOARD

# Clerk route configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Convex (https://dashboard.convex.dev → your project → Settings)
NEXT_PUBLIC_CONVEX_URL=https://GET_FROM_CONVEX_DASHBOARD.convex.cloud


# Google Calendar (Clerk manages OAuth tokens — no secrets stored here)
#
# REQUIRED SETUP in Clerk Dashboard before Calendar sync will work:
# 1. Dashboard → User & Authentication → Social Connections → Google → Enable
# 2. Under "Scopes", add: https://www.googleapis.com/auth/calendar
# 3. Save changes — users will be prompted for Calendar access on next sign-in
#
# CONVEX_INTERNAL_SECRET (already required above for Canvas) also authorizes
# the Google Calendar sync route to write to Convex. No extra secrets needed.

# LLM / AI Provider (set in Convex, not .env.local)
# Team-provisioned Groq key powers AI chat for all students — no per-student setup needed.
# Sign up at https://console.groq.com (free, no credit card) → API Keys
# Free tier: 14,400 req/day, 30 req/min per model
# Set via:  npx convex env set GROQ_API_KEY gsk_...
# GROQ_API_KEY=gsk_GET_FROM_GROQ_CONSOLE